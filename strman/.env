# 项目环境配置

# ===================
# Python 环境配置
# ===================
# 项目使用 Python 3.11
# 请确保使用 conda 环境运行

# conda 环境名称
CONDA_ENV_NAME=fastwhisper

# Python 版本
PYTHON_VERSION=3.11

# ===================
# 依赖安装
# ===================
# 使用 conda 创建环境:
# conda create -n fastwhisper python=3.11
# conda activate fastwhisper
# pip install -r requirements.txt

# ===================
# 常用命令
# ===================
# 激活环境: conda activate fastwhisper
# 测试运行: python main.py <video_url>
# 或使用 run.bat: run.bat <video_url>

# ===================
# CUDA 加速 (可选)
# ===================
# 如需 GPU 加速，安装:
# pip install nvidia-cublas-cu12 nvidia-cudnn-cu12